{
  "name": "markast",
  "version": "0.1.0",
  "description": "Rust-powered markdown to HTML renderer with customizable styles",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericyangpan/markast.git"
  },
  "homepage": "https://github.com/ericyangpan/markast#readme",
  "bugs": {
    "url": "https://github.com/ericyangpan/markast/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "markast-darwin-arm64": "0.1.0",
    "markast-darwin-x64": "0.1.0",
    "markast-linux-arm64-gnu": "0.1.0",
    "markast-linux-x64-gnu": "0.1.0",
    "markast-win32-x64-msvc": "0.1.0"
  },
  "bin": {
    "markast": "bin/markast.js"
  },
  "files": [
    "Cargo.toml",
    "Cargo.lock",
    "src",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "cargo build --release",
    "dev": "cargo run --",
    "test": "cargo test --all-targets",
    "test:own": "cargo test --test own_rendering",
    "test:compat": "npm run test:compat:snapshot && npm run test:compat:runtime",
    "test:compat:snapshot": "cargo test --test compat_snapshot",
    "test:compat:snapshot:update-xfail": "./scripts/update-compat-xfail.sh",
    "test:compat:update-xfail": "npm run test:compat:snapshot:update-xfail",
    "test:compat:runtime": "cargo test --test compat_runtime",
    "test:compat:runtime:update-xfail": "MARKAST_WRITE_RUNTIME_XFAIL=1 cargo test --test compat_runtime -- --nocapture",
    "test:compat:runtime-drift": "node scripts/check-marked-runtime-drift.mjs",
    "test:compat:report": "node scripts/compat-report.mjs",
    "check": "cargo check",
    "check:strict": "node scripts/check-strict.mjs",
    "sync:npm-versions": "node scripts/sync-npm-versions.mjs",
    "check:npm-versions": "node scripts/check-npm-versions.mjs",
    "bench": "node scripts/benchmark.mjs --write-readme"
  },
  "keywords": [
    "markdown",
    "rust",
    "cli",
    "html",
    "css"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "markdown-it": "^14.1.1",
    "marked": "17.0.4",
    "remark": "15.0.1",
    "remark-gfm": "4.0.1",
    "remark-html": "16.0.1"
  }
}
